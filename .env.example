# Zealthy — environment variables
# Copy this file to `.env` and fill in real values. `.env` is git-ignored.

# Postgres connection string (Neon in production; any Postgres locally).
# Neon: use the "Pooled connection" string. Example:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
DATABASE_URL="postgresql://user:password@localhost:5432/zealthy?schema=public"

# Auth.js (NextAuth v5) session-signing secret.
# Generate one with:  npx auth secret     (or)     openssl rand -base64 32
AUTH_SECRET="replace-with-a-generated-secret"
